DATABASE_URL=postgresql://todo_user:password@localhost:5432/todo_db
PORT=4000
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
API_JSON_LIMIT=2mb
WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
WEB_PUSH_VAPID_SUBJECT=mailto:you@example.com
REMINDER_ALLOW_MULTIPLE_PER_DAY=false
REMINDER_JOB_SECRET=generate-a-long-random-secret
REMINDER_REPEAT_GAP_MS=600000
REMINDER_JOB_BATCH_LIMIT=100
REMINDER_JOB_MAX_BATCHES_PER_RUN=50
REMINDER_CLAIM_STALE_AFTER_MS=600000

# For mobile testing on same network: HOST=0.0.0.0 (makes API reachable from other devices)
